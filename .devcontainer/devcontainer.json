{
  "name": "Power BI Model Advisor",
  "image": "mcr.microsoft.com/devcontainers/python:3.11",
  "forwardPorts": [8000, 5500],
  "portsAttributes": {
    "8000": { "label": "FastAPI Backend", "onAutoForward": "notify" },
    "5500": { "label": "Frontend (Live Server)", "onAutoForward": "openBrowser" }
  },
  "postCreateCommand": "pip install -r backend/requirements.txt",
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ritwickdey.LiveServer",
        "ms-python.vscode-pylance"
      ],
      "settings": {
        "liveServer.settings.port": 5500,
        "liveServer.settings.root": "/frontend"
      }
    }
  }
}
